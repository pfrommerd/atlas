// USE+MAT stress: recursively peels a constructor argument through
// a strict USE wrapper, controlled by numeric depth.
@mk = λ{
  0n: #Z{}
  1n+: λp. #S{@mk(p)}
}

@peel = λ{
  0n: λx. x
  1n+: λd. λx.
    ((λ{λv. λ{
      #Z: #Z{}
      #S: λp. @peel(d, p)
    }(v)})(x))
}

@run = λ&d. @peel(d, @mk(d))
@main = @run(100000n)
//#Z{}
